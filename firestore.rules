rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    // Collection: users
    // Document ID: {userId}
    // Fields: uid, email, displayName, businessName, businessPhone, businessAddress
    //
    // Collection: budgets
    // Document ID: {budgetId}
    // Fields: id, userId, clientName, clientPhone, clientAddress, date, items, totalAmount, status, notes
    //
    // Collection: transactions
    // Document ID: {transactionId}
    // Fields: id, userId, type, category, amount, date, description, budgetId
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isDocOwner() {
      return isAuthenticated() && request.auth.uid == resource.data.userId;
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email']) &&
             data.uid is string &&
             data.email is string;
    }

    function isValidBudget(data) {
      return data.keys().hasAll(['userId', 'clientName', 'totalAmount', 'status']) &&
             data.userId == request.auth.uid &&
             data.totalAmount is number &&
             data.status in ['pending', 'approved', 'completed', 'cancelled'];
    }

    function isValidTransaction(data) {
      return data.keys().hasAll(['userId', 'type', 'amount', 'date']) &&
             data.userId == request.auth.uid &&
             data.amount is number &&
             data.type in ['income', 'expense'];
    }

    // Rules
    match /users/{userId} {
      allow read: if isOwner(userId);
      allow create, update: if isOwner(userId) && isValidUser(request.resource.data);
    }

    match /clients/{clientId} {
      allow read: if isAuthenticated() && (resource == null || resource.data.userId == request.auth.uid);
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isDocOwner();
    }

    match /budgets/{budgetId} {
      allow read: if isAuthenticated() && (resource == null || resource.data.userId == request.auth.uid);
      allow create: if isAuthenticated() && isValidBudget(request.resource.data);
      allow update: if isDocOwner() && isValidBudget(request.resource.data);
      allow delete: if isDocOwner();
    }

    match /transactions/{transactionId} {
      allow read: if isAuthenticated() && (resource == null || resource.data.userId == request.auth.uid);
      allow create: if isAuthenticated() && isValidTransaction(request.resource.data);
      allow update: if isDocOwner() && isValidTransaction(request.resource.data);
      allow delete: if isDocOwner();
    }
  }
}
